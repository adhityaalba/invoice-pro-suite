# Vercel Postgres Database Connection
# Get this from your Vercel Dashboard → Project → Storage → Postgres
DATABASE_URL="postgresql://user:password@host/database?sslmode=require"

# Alternative: Vercel Postgres environment variable (auto-set by Vercel)
# POSTGRES_URL="postgresql://..."

# Optional: For local development with a local PostgreSQL instance
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/invoice_pro"
